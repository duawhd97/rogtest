<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Virtual Realogram — Layout Test</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f4f4f2;
      padding: 24px;
      color: #1a1a1a;
    }

    h1 {
      font-size: 16px;
      font-weight: 500;
      margin-bottom: 4px;
    }

    .subtitle {
      font-size: 12px;
      color: #888;
      margin-bottom: 24px;
    }

    /* ── Controls ── */
    .controls {
      background: white;
      border: 0.5px solid #ddd;
      border-radius: 10px;
      padding: 16px 20px;
      margin-bottom: 20px;
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      align-items: center;
    }

    .control-group {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: #555;
    }

    .control-group label { white-space: nowrap; }

    input[type="range"] { width: 120px; }

    input[type="number"] {
      width: 60px;
      padding: 4px 6px;
      border: 0.5px solid #ccc;
      border-radius: 5px;
      font-size: 13px;
    }

    button {
      padding: 6px 14px;
      font-size: 13px;
      border: 0.5px solid #ccc;
      border-radius: 6px;
      background: white;
      cursor: pointer;
    }
    button:hover { background: #f5f5f5; }
    button.primary {
      background: #1a1a1a;
      color: white;
      border-color: #1a1a1a;
    }
    button.primary:hover { background: #333; }

    /* ── Realogram Container ── */
    .realogram-container {
      width: 100%;
      max-width: 960px;
      margin: 0 auto;
    }

    .shelf-row {
      display: flex;
      width: 100%;
      /* height는 JS에서 주입 */
      border: 1px solid #d0d0d0;
      border-radius: 6px;
      overflow: hidden;
      margin-bottom: 6px;
      background: #f0f0ee;
    }

    .shelf-cell {
      /* flex-basis는 JS에서 주입 */
      height: 100%;
      flex-shrink: 0;
      background: #ffffff;
      border-right: 0.5px solid #e0e0e0;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
      transition: background 0.15s;
    }

    .shelf-cell:last-child { border-right: none; }

    .shelf-cell:hover { background: #fafafa; }

    /* 핵심: object-fit contain */
    .shelf-cell img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }

    /* OOS placeholder */
    .shelf-cell.oos {
      background: #f9f9f9;
    }

    .oos-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      width: 100%;
      height: 100%;
    }

    .oos-icon {
      width: 28px;
      height: 28px;
      border: 1.5px dashed #bbb;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #bbb;
      font-size: 16px;
    }

    .oos-label {
      font-size: 10px;
      font-weight: 500;
      color: #bbb;
      letter-spacing: 0.05em;
    }

    /* 셀 너비 퍼센트 툴팁 */
    .cell-pct {
      position: absolute;
      bottom: 3px;
      right: 4px;
      font-size: 9px;
      color: #bbb;
      pointer-events: none;
    }

    /* ── Image Upload Area ── */
    .upload-section {
      background: white;
      border: 0.5px solid #ddd;
      border-radius: 10px;
      padding: 16px 20px;
      margin-bottom: 20px;
    }

    .upload-section h2 {
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 12px;
      color: #555;
    }

    .drop-zone {
      border: 1.5px dashed #ccc;
      border-radius: 8px;
      padding: 24px;
      text-align: center;
      font-size: 13px;
      color: #999;
      cursor: pointer;
      transition: border-color 0.15s;
    }
    .drop-zone:hover, .drop-zone.drag-over { border-color: #888; color: #555; }

    .image-slots {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .image-slot {
      width: 80px;
      height: 80px;
      border: 0.5px solid #ddd;
      border-radius: 6px;
      overflow: hidden;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #f9f9f9;
    }

    .image-slot img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .image-slot .remove-btn {
      position: absolute;
      top: 2px;
      right: 2px;
      width: 16px;
      height: 16px;
      background: rgba(0,0,0,0.5);
      border: none;
      border-radius: 50%;
      color: white;
      font-size: 10px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
    }

    /* ── Mock data selector ── */
    .mock-selector {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .mock-btn {
      font-size: 12px;
      padding: 4px 10px;
    }

    .section-title {
      font-size: 12px;
      font-weight: 500;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 10px;
    }

    .divider {
      border: none;
      border-top: 0.5px solid #e5e5e5;
      margin: 16px 0;
    }

    .info-bar {
      font-size: 11px;
      color: #aaa;
      margin-bottom: 10px;
    }
  </style>
</head>
<body>

<h1>Virtual Realogram — Layout Test</h1>
<p class="subtitle">object-fit: contain 기반 셀 렌더링 · bbox 너비 비율 기반 셀 크기</p>

<!-- Controls -->
<div class="controls">
  <div class="control-group">
    <label>Row 높이</label>
    <input type="range" id="rowHeight" min="60" max="240" value="120" oninput="updateRowHeight(this.value)">
    <span id="rowHeightVal">120px</span>
  </div>
  <div class="control-group">
    <label>컨테이너 최대 너비</label>
    <input type="number" id="maxWidth" value="960" min="300" max="1400" step="10" oninput="updateMaxWidth(this.value)">
    <span>px</span>
  </div>
  <div class="control-group">
    <label>셀 배경</label>
    <input type="color" id="cellBg" value="#ffffff" oninput="updateCellBg(this.value)">
  </div>
  <div class="control-group">
    <label>너비 % 표시</label>
    <input type="checkbox" id="showPct" checked onchange="togglePct(this.checked)">
  </div>
  <button class="primary" onclick="rerenderAll()">다시 렌더</button>
</div>

<!-- Mock Data Section -->
<div class="upload-section">
  <h2>테스트 데이터 선택</h2>
  <div class="section-title">Mock 시나리오</div>
  <div class="mock-selector">
    <button class="mock-btn" onclick="loadMock('convenience')">편의점 과자 선반</button>
    <button class="mock-btn" onclick="loadMock('wine')">와인 + 음료 (세로형 혼합)</button>
    <button class="mock-btn" onclick="loadMock('mixed')">혼합형 (라면+칫솔+박스)</button>
  </div>

  <hr class="divider">

  <div class="section-title">실제 이미지로 테스트</div>
  <div class="drop-zone" id="dropZone" onclick="document.getElementById('fileInput').click()">
    이미지를 드래그하거나 클릭해서 업로드 (여러 장 가능)<br>
    <span style="font-size:11px;color:#bbb">업로드한 이미지는 순서대로 셀에 배치됩니다</span>
  </div>
  <input type="file" id="fileInput" multiple accept="image/*" style="display:none" onchange="handleFiles(this.files)">
  <div class="image-slots" id="imageSlots"></div>

  <div style="margin-top:12px;display:flex;gap:8px;align-items:center;">
    <div class="control-group">
      <label>행당 셀 수</label>
      <input type="number" id="cellsPerRow" value="4" min="1" max="12" style="width:50px">
    </div>
    <button onclick="renderFromUploads()">업로드 이미지로 렌더</button>
  </div>
</div>

<!-- Realogram Output -->
<div class="info-bar" id="infoBar"></div>
<div class="realogram-container" id="realogramContainer"></div>

<script>
  /* ─── State ─── */
  let currentRowHeight = 120;
  let currentMaxWidth = 960;
  let currentCellBg = '#ffffff';
  let showPct = true;
  let uploadedImages = [];   // { url, name }
  let currentData = null;    // [row] where row = [{ label, bboxW, type }]

  /* ─── Mock Data ─── */
  const MOCKS = {
    convenience: [
      [
        { label: '탱글면 × 3\n(wide)', bboxW: 337, color: '#f5c4b3' },
        { label: '비초비',             bboxW: 80,  color: '#c0dd97' },
        { label: '컵라면',             bboxW: 55,  color: '#b5d4f4' },
        { label: '초코파이\n찰떡',     bboxW: 160, color: '#fac775' },
        { label: '초코파이\n찰떡2',    bboxW: 155, color: '#fac775' },
      ],
      [
        { label: '칸쵸',              bboxW: 70,  color: '#f4c0d1' },
        { label: '누텔라',            bboxW: 80,  color: '#d3d1c7' },
        { label: '컵라면',            bboxW: 55,  color: '#b5d4f4' },
        { label: '초코파이\n큰박스',  bboxW: 210, color: '#fac775' },
        { label: '버터와플',          bboxW: 90,  color: '#c0dd97' },
        { label: '버터와플2',         bboxW: 90,  color: '#c0dd97' },
        { label: '조크픽',            bboxW: 65,  color: '#f5c4b3' },
        { label: 'OOS',               bboxW: 60,  color: null, oos: true },
      ],
      [
        { label: '나!나!\n과자',      bboxW: 130, color: '#f5c4b3' },
        { label: '컵라면',            bboxW: 55,  color: '#b5d4f4' },
        { label: '가나\n박스',        bboxW: 140, color: '#d3d1c7' },
        { label: '탱글 컵',           bboxW: 75,  color: '#f4c0d1' },
        { label: '에이스',            bboxW: 120, color: '#c0dd97' },
        { label: '조크픽\n세트',      bboxW: 95,  color: '#fac775' },
        { label: '칸쵸',              bboxW: 80,  color: '#f4c0d1' },
      ],
    ],

    wine: [
      [
        { label: '레드 와인\n(tall)',  bboxW: 45,  color: '#cecbf6', aspectTall: true },
        { label: '화이트와인\n(tall)', bboxW: 45,  color: '#cecbf6', aspectTall: true },
        { label: '맥주캔',            bboxW: 60,  color: '#fac775' },
        { label: '맥주캔2',           bboxW: 60,  color: '#fac775' },
        { label: '소주',              bboxW: 50,  color: '#b5d4f4', aspectTall: true },
        { label: '소주2',             bboxW: 50,  color: '#b5d4f4', aspectTall: true },
        { label: '과일주스\n팩',      bboxW: 90,  color: '#c0dd97' },
        { label: 'OOS',               bboxW: 55,  color: null, oos: true },
      ],
      [
        { label: '로제 와인\n(tall)',  bboxW: 45,  color: '#f4c0d1', aspectTall: true },
        { label: '스파클링\n(tall)',   bboxW: 48,  color: '#cecbf6', aspectTall: true },
        { label: '막걸리\n(tall)',     bboxW: 60,  color: '#d3d1c7', aspectTall: true },
        { label: '에너지드링크',       bboxW: 55,  color: '#c0dd97' },
        { label: '에너지드링크2',      bboxW: 55,  color: '#c0dd97' },
        { label: '커피음료',           bboxW: 70,  color: '#d3d1c7' },
        { label: 'OOS',               bboxW: 48,  color: null, oos: true },
      ],
    ],

    mixed: [
      [
        { label: '라면 박스\n(wide)',  bboxW: 260, color: '#f5c4b3' },
        { label: '컵라면',            bboxW: 70,  color: '#b5d4f4' },
        { label: '칫솔\n(tall)',       bboxW: 30,  color: '#cecbf6', aspectTall: true },
        { label: '칫솔2\n(tall)',      bboxW: 30,  color: '#cecbf6', aspectTall: true },
        { label: '샴푸',              bboxW: 65,  color: '#c0dd97', aspectTall: true },
      ],
      [
        { label: '과자 박스',         bboxW: 180, color: '#fac775' },
        { label: '쿠크다스',          bboxW: 120, color: '#c0dd97' },
        { label: '탱글면\n(wide)',     bboxW: 160, color: '#f5c4b3' },
        { label: 'OOS',               bboxW: 70,  color: null, oos: true },
        { label: '가나 초코',         bboxW: 90,  color: '#d3d1c7' },
      ],
    ],
  };

  /* ─── Render ─── */
  function renderRealogram(rows) {
    currentData = rows;
    const container = document.getElementById('realogramContainer');
    container.style.maxWidth = currentMaxWidth + 'px';
    container.innerHTML = '';

    rows.forEach((row, ri) => {
      const totalW = row.reduce((s, item) => s + item.bboxW, 0);
      const rowEl = document.createElement('div');
      rowEl.className = 'shelf-row';
      rowEl.style.height = currentRowHeight + 'px';

      row.forEach((item, ci) => {
        const pct = (item.bboxW / totalW * 100).toFixed(1);
        const cell = document.createElement('div');
        cell.className = 'shelf-cell' + (item.oos ? ' oos' : '');
        cell.style.flexBasis = pct + '%';
        cell.style.background = currentCellBg;

        if (item.oos) {
          cell.innerHTML = `
            <div class="oos-inner">
              <div class="oos-icon">✕</div>
              <div class="oos-label">OOS</div>
            </div>`;
        } else if (item.url) {
          // 실제 이미지
          const img = document.createElement('img');
          img.src = item.url;
          img.alt = item.label || '';
          cell.appendChild(img);
        } else {
          // Mock placeholder
          const inner = document.createElement('div');
          const isTall = item.aspectTall;
          const h = isTall ? Math.round(currentRowHeight * 0.88) : Math.round(currentRowHeight * 0.68);
          const w = isTall ? Math.round(currentRowHeight * 0.22) : Math.min(Math.round(item.bboxW / totalW * 700), 120);
          inner.style.cssText = `
            width: ${Math.max(w, 14)}px;
            height: ${Math.min(h, currentRowHeight - 8)}px;
            background: ${item.color};
            border-radius: 3px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            color: #555;
            text-align: center;
            line-height: 1.3;
            white-space: pre-line;
          `;
          inner.textContent = item.label;
          cell.appendChild(inner);
        }

        if (showPct) {
          const pctEl = document.createElement('span');
          pctEl.className = 'cell-pct';
          pctEl.textContent = pct + '%';
          cell.appendChild(pctEl);
        }

        rowEl.appendChild(cell);
      });

      container.appendChild(rowEl);
    });

    document.getElementById('infoBar').textContent =
      `${rows.length}개 선반 · 총 ${rows.reduce((s,r)=>s+r.length,0)}개 셀 · Row 높이 ${currentRowHeight}px · 컨테이너 최대 ${currentMaxWidth}px`;
  }

  /* ─── Mock loader ─── */
  function loadMock(key) {
    renderRealogram(MOCKS[key]);
  }

  /* ─── Controls ─── */
  function updateRowHeight(v) {
    currentRowHeight = parseInt(v);
    document.getElementById('rowHeightVal').textContent = v + 'px';
    if (currentData) renderRealogram(currentData);
  }

  function updateMaxWidth(v) {
    currentMaxWidth = parseInt(v) || 960;
    if (currentData) renderRealogram(currentData);
  }

  function updateCellBg(v) {
    currentCellBg = v;
    if (currentData) renderRealogram(currentData);
  }

  function togglePct(v) {
    showPct = v;
    if (currentData) renderRealogram(currentData);
  }

  function rerenderAll() {
    if (currentData) renderRealogram(currentData);
  }

  /* ─── File Upload ─── */
  const dropZone = document.getElementById('dropZone');
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    handleFiles(e.dataTransfer.files);
  });

  function handleFiles(files) {
    Array.from(files).forEach(file => {
      if (!file.type.startsWith('image/')) return;
      const reader = new FileReader();
      reader.onload = e => {
        uploadedImages.push({ url: e.target.result, name: file.name });
        renderImageSlots();
      };
      reader.readAsDataURL(file);
    });
  }

  function renderImageSlots() {
    const slots = document.getElementById('imageSlots');
    slots.innerHTML = '';
    uploadedImages.forEach((img, i) => {
      const slot = document.createElement('div');
      slot.className = 'image-slot';
      slot.innerHTML = `
        <img src="${img.url}" alt="${img.name}">
        <button class="remove-btn" onclick="removeImage(${i})">✕</button>
      `;
      slots.appendChild(slot);
    });
  }

  function removeImage(i) {
    uploadedImages.splice(i, 1);
    renderImageSlots();
  }

  function renderFromUploads() {
    if (uploadedImages.length === 0) { alert('이미지를 먼저 업로드해주세요.'); return; }
    const perRow = parseInt(document.getElementById('cellsPerRow').value) || 4;

    // 이미지를 행으로 분할
    const rows = [];
    for (let i = 0; i < uploadedImages.length; i += perRow) {
      const rowImgs = uploadedImages.slice(i, i + perRow);
      // bbox width를 알 수 없으므로 균등 분배 (실제 구현 시 API 데이터로 대체)
      const row = rowImgs.map(img => ({
        label: img.name,
        bboxW: 100,  // 균등 너비 (실제 bbox 없을 때 fallback)
        url: img.url,
      }));
      rows.push(row);
    }
    renderRealogram(rows);
  }

  /* ─── Init: 기본 mock 로드 ─── */
  loadMock('convenience');
</script>
</body>
</html>
